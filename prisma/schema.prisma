generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Addresses {
  id         Int       @id @default(autoincrement())
  userId     String    @db.Uuid
  name       String
  address    String
  zipcode    String
  city       String
  country    String
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  user       User      @relation("UserAddresses", fields: [userId], references: [id])
}

model Orders {
  id         Int         @id @default(autoincrement())
  userId     String      @db.Uuid
  stripeId   String
  name       String
  address    String
  zipcode    String
  city       String
  country    String
  created_at DateTime?   @default(now()) @db.Timestamptz(6)
  confirmed  Boolean     @default(false)
  orderItem  OrderItem[]
  user       User        @relation("UserOrders", fields: [userId], references: [id])
}

model OrderItem {
  id            Int            @id @default(autoincrement())
  orderId       Int
  productId     Int
  created_at    DateTime?      @default(now()) @db.Timestamptz(6)
  order         Orders         @relation(fields: [orderId], references: [id])
  product       Products       @relation(fields: [productId], references: [id])
  returnRequest ReturnRequest?
}

model Products {
  id          Int            @id @default(autoincrement())
  title       String
  description String
  url         String
  price       Int
  created_at  DateTime?      @default(now()) @db.Timestamptz(6)
  category    String
  sellerId    String?        @db.Uuid
  images      ProductImage[]
  buybacks    BuybackOffer[]
  orderItem   OrderItem[]
  seller      User?          @relation(fields: [sellerId], references: [id])
}

enum UserLevel {
  VIP1
  VIP2
}

model User {
  id              String         @id @default(uuid()) @db.Uuid
  email           String         @unique
  password        String
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  balance         Int            @default(0)
  deals           Int            @default(0)
  fullName        String?
  isBlocked       Boolean        @default(false)
  isBalanceFrozen Boolean        @default(false)
  level           UserLevel      @default(VIP1)
  managerId       String?        @db.Uuid
  manager         User?          @relation("UserToManager", fields: [managerId], references: [id])
  referrals       User[]         @relation("UserToManager") // ← подчинённые (пользователи менеджера)
  phone           String?
  refCode         String?        @unique
  managedBuybacks BuybackOffer[] @relation("UserManagedBuybacks")
  reputation      Int            @default(0)
  avatar          String?
  role            String?        @default("USER")
  updatedAt       DateTime       @default(now()) @db.Timestamptz(6)
  username        String?
  activities      ActivityLog[]
  addresses       Addresses[]    @relation("UserAddresses")
  bankCards       BankCard[]     @relation("UserBankCards")
  buybacks        BuybackOffer[]
  chatMessages    ChatMessage[]
  orders          Orders[]       @relation("UserOrders")
  products        Products[]
  referralLinks   ReferralLink[] @relation("UserReferrals")
  topups          TopUpRequest[]
  transactions    Transaction[]
  withdrawals     Withdrawal[]
  posts           Post[]
}

model Post {
  id        Int      @id @default(autoincrement())
  authorId  String   @db.Uuid
  title     String
  content   String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  author    User     @relation(fields: [authorId], references: [id])
}

model BankCard {
  id         Int      @id @default(autoincrement())
  userId     String   @db.Uuid
  name       String
  cardNumber String
  expiry     String
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  user       User     @relation("UserBankCards", fields: [userId], references: [id])
}

model ReturnRequest {
  id          Int          @id @default(autoincrement())
  orderItemId Int          @unique
  status      ReturnStatus @default(NOT_SENT)
  amount      Int?
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  confirmed   Boolean      @default(false)
  orderItem   OrderItem    @relation(fields: [orderItemId], references: [id])
}

model Withdrawal {
  id        Int              @id @default(autoincrement())
  userId    String           @db.Uuid
  amount    Int
  cardInfo  String
  status    WithdrawalStatus @default(PENDING)
  createdAt DateTime         @default(now()) @db.Timestamptz(6)
  user      User             @relation(fields: [userId], references: [id])

  // 🔗 Обратная связь на транзакцию
  transaction Transaction[]
}

model BuybackOffer {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  managerId String?  @db.Uuid
  percent   Int      @default(25)
  productId Int
  price     Int
  reward    Int?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  status    String?

  product Products @relation(fields: [productId], references: [id])
  user    User     @relation(fields: [userId], references: [id])
  manager User?    @relation("UserManagedBuybacks", fields: [managerId], references: [id])
}

model Transaction {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  type      String   // 'TOPUP' или 'WITHDRAWAL'
  amount    Int
  details   String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user      User     @relation(fields: [userId], references: [id])

  // 🔗 Связь с заявкой на пополнение
  topUpRequestId Int?
  topUpRequest   TopUpRequest? @relation(fields: [topUpRequestId], references: [id])

  // 🔗 Связь с заявкой на вывод
  withdrawalId   Int?
  withdrawal     Withdrawal?   @relation(fields: [withdrawalId], references: [id])
}

model ReferralLink {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  managerId String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  manager   User     @relation("UserReferrals", fields: [managerId], references: [id])
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    String   @db.Uuid
  action    String
  meta      String?
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [userId], references: [id])
}

model PasswordResetCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}


model TopUpRequest {
  id        Int         @id @default(autoincrement())
  userId    String      @db.Uuid
  amount    Int
  status    TopUpStatus @default(PENDING)
  createdAt DateTime    @default(now()) @db.Timestamptz(6)
  stripeId  String?     @db.VarChar(255)
  user      User        @relation(fields: [userId], references: [id])

  // 🔗 Обратная связь на транзакцию
  transaction Transaction[]
}

model ChatMessage {
  id          Int      @id @default(autoincrement())
  userId      String   @db.Uuid
  message     String
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  isFromAdmin Boolean  @default(false)
  user        User     @relation(fields: [userId], references: [id])
}

enum ReturnStatus {
  PENDING
  NOT_SENT
  SENT
  COMPLETED
}

enum WithdrawalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TopUpStatus {
  PENDING
  APPROVED
  REJECTED
}

model ProductImage {
  id        Int       @id @default(autoincrement())
  productId Int
  url       String
  createdAt DateTime  @default(now())

  product   Products  @relation(fields: [productId], references: [id], onDelete: Cascade)
}
